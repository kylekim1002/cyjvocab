# --- Supabase (클라이언트/스토리지 등) ---
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]
# 학생 전역 배경 WebP 전용 버킷(선택, 기본값 student-backgrounds). 미설정 시 앱이 public 버킷을 자동 생성 시도합니다.
# SUPABASE_STUDENT_BACKGROUND_BUCKET=student-backgrounds

# --- Prisma / PostgreSQL ---
# 로컬: 직접 연결이면 DATABASE_URL과 DIRECT_URL을 동일하게 두면 됩니다.
#
# Vercel + Supabase (권장):
# - 런타임 DATABASE_URL = Transaction pooler (보통 포트 6543, 호스트에 pooler 포함)
#   Prisma 서버리스 권장 쿼리: pgbouncer=true, connection_limit=1 (앱에서 풀러 URL이면 자동 보강하기도 함)
# - DIRECT_URL = 직접 연결 5432 (migrate / db push 전용)
#
# 예시 (자리 표시자만 실제 값으로 교체):
# DATABASE_URL="postgresql://USER:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

NODE_ENV="development"

# --- Upstash Redis (선택, 권장: 프로덕션 자동로그인 IP 레이트리밋 전역 공유) ---
# Vercel 대시보드에서 Upstash 연동 시 자동 주입되거나, 아래를 직접 설정합니다.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."
